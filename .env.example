# Baltimore County GIS layer URLs (optional).
# If not set, district lookups will return no data until you add the correct URLs.
#
# How to get the Feature Server URL:
# 1. Open https://opendata.baltimorecountymd.gov
# 2. Search for "Councilmanic Districts" and for "Bill 55-25 - As Amended"
# 3. Open each dataset -> look for "API" or "Query" or "View" -> copy the Feature Server base URL (e.g. .../FeatureServer/0 without /query)
#
# Current (7) councilmanic districts (MapServer):
BC_CURRENT_DISTRICTS_LAYER_URL=https://bcgisdata.baltimorecountymd.gov/arcgis/rest/services/Political/Political/MapServer/3
#
# Future (2026) districts - Bill 55-25 - As Amended (9 districts, FeatureServer):
BC_FUTURE_DISTRICTS_LAYER_URL=https://services2.arcgis.com/Ynpzre7M7vSGY7dh/arcgis/rest/services/Bill%2055-25%20Proposed%20Council%20Amendment/FeatureServer/0

# Override geocoder (default: Baltimore County AddressPointGeocoder)
# BC_GEOCODER_URL=https://bcgis.baltimorecountymd.gov/arcgis/rest/services/Geocoders/AddressPointGeocoder/GeocodeServer

# USPS address autocomplete (Smarty US Autocomplete Pro). Get keys at https://www.smarty.com/
# Without these, the address field has no suggestions (user can still type and submit).
SMARTY_AUTH_ID=
SMARTY_AUTH_TOKEN=
